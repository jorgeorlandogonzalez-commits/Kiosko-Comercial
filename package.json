{
  "name": "kiosko-comercial",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:server": "tsx watch server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "lint": "tsc --noEmit",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "deploy": "bash deploy.sh all prod",
    "deploy:win": "powershell -ExecutionPolicy Bypass -File deploy.ps1 all prod",
    "deploy:hosting": "bash deploy.sh hosting prod",
    "deploy:hosting:win": "powershell -ExecutionPolicy Bypass -File deploy.ps1 hosting prod",
    "deploy:functions": "bash deploy.sh functions prod",
    "deploy:rules": "bash deploy.sh rules prod",
    "deploy:cloud-run": "bash deploy.sh cloud-run prod"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.1.1",
    "@google/genai": "^1.30.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "fast-xml-parser": "^5.7.2",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.554.0",
    "node-forge": "^1.4.0",
    "pino": "^10.3.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.4.1",
    "xml-crypto": "^6.1.2",
    "xmldom": "^0.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.28.1",
    "firebase-tools": "^15.22.4",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
