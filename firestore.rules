rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===== 0. Global Safety Net (Deny by Default) =====
    match /{document=**} {
      allow read, write: if false;
    }

    // ===== Helpers de Autenticación y Roles =====
    
    function isOwner(userId) { 
       return request.auth != null && request.auth.uid == userId;
    }
    
    function isOperator(userId) {
      return isOwner(userId) || exists(/databases/$(database)/documents/users/$(userId)/operators/$(request.auth.uid));
    }
    
    function isAdmin(userId) {
      return isOwner(userId) || (
        exists(/databases/$(database)/documents/users/$(userId)/operators/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(userId)/operators/$(request.auth.uid)).data.role == 'ADMIN'
      );
    }

    function isValidId(id) { 
       return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===== Validadores de Dominio (Hardened para DIAN) =====
    
    function isValidCartItem(item) {
      return item is map &&
             item.id is string && item.id.size() > 0 &&
             item.name is string && item.name.size() > 0 && item.name.size() <= 200 &&
             item.price is number && item.price >= 0 &&
             item.quantity is number && item.quantity > 0;
    }

    function isValidProduct(data) {
      return data is map &&
             data.keys().hasAll(['id', 'name', 'price']) &&
             data.id is string && data.id.size() > 0 && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0;
    }

    function isValidInvoice(data) {
      return data is map &&
             data.id is string && data.id.size() > 0 && data.id.size() <= 128 &&
             data.total is number && data.total >= 0 && data.total <= 1000000000 &&
             data.dianStatus in ['DRAFT', 'SENDING', 'APPROVED', 'REJECTED'] &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 600 &&
             isValidCartItem(data.items[0]) &&
             data.customerNit is string && data.customerNit.size() > 0 && data.customerNit.size() <= 30 &&
             data.customerName is string && data.customerName.size() > 0;
    }

    function isValidInvoiceForCreate(data) {
      return isValidInvoice(data) && (data.dianStatus == 'DRAFT' || data.dianStatus == 'SENDING');
    }

    // Transiciones válidas de estados DIAN
    function isValidInvoiceTransition(oldData, newData) {
      return (oldData.dianStatus == 'DRAFT' && (newData.dianStatus == 'SENDING' || newData.dianStatus == 'REJECTED')) ||
             (oldData.dianStatus == 'SENDING' && (newData.dianStatus == 'APPROVED' || newData.dianStatus == 'REJECTED' || newData.dianStatus == 'DRAFT')) ||
             (oldData.dianStatus == 'REJECTED' && (newData.dianStatus == 'DRAFT' || newData.dianStatus == 'SENDING'));
    }

    // Validación de cliente para factura electrónica (tolera valores opcionales)
    function isValidCustomerForFE(data) {
      return data.customerNit == '222222222222' || (
        data.customerName is string && data.customerName.size() > 3 &&
        (!('customerPhone' in data) || data.customerPhone == null || data.customerPhone == '' || data.customerPhone is string) &&
        (!('customerEmail' in data) || data.customerEmail == null || data.customerEmail == '' || (data.customerEmail is string && data.customerEmail.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$')))
      );
    }

    // ===== Reglas de Suscripción =====
    match /subscriptions/{userId} {
      allow read: if isOperator(userId);
      
      allow create: if isOwner(userId) && 
                    incoming().userId == userId && 
                    incoming().status == 'trial';
      allow update: if isOwner(userId) && 
                    (
                      // Can update itself if changing status requires a signature
                      (incoming().status == 'active' && incoming().signature == hashing.sha256(utf8.encode(userId + 'ACTIVE' + 'KIOSKO_SECURE_PAYMENTS_2026')).toHexString()) ||
                      // Or can mark as expired if it was trial
                      (existing().status == 'trial' && incoming().status == 'expired') ||
                      // If it's already ACTIVE, allow updating signature? No, just keep it.
                      (existing().status == 'active' && incoming().status == 'active')
                    );
    }

    // ===== Reglas de Usuario =====
    match /users/{userId} {
      // ✅ CORREGIDO: Permitir que el usuario cree su propio documento al registrarse
      allow read: if isOperator(userId);
      allow create: if isOwner(userId);

      match /storeSettings/{settingId} {
        allow read: if isOperator(userId);
        allow write: if isAdmin(userId) && isValidId(settingId);
      }

      match /products/{productId} {
        allow read: if isOperator(userId);
        allow create, update: if isAdmin(userId) && isValidId(productId) && 
                              incoming() is map && isValidProduct(incoming());
        allow delete: if isAdmin(userId);
      }

      match /invoices/{invoiceId} {
        allow read: if isOperator(userId);
        
        allow create: if isOperator(userId) && 
                      isValidId(invoiceId) && 
                      isValidInvoiceForCreate(incoming()) &&
                      isValidCustomerForFE(incoming());
        
        allow update: if isOperator(userId) && 
                      isValidInvoice(incoming()) &&
                      existing().dianStatus != 'APPROVED' &&
                      isValidInvoiceTransition(existing(), incoming()) &&
                      incoming().id == existing().id &&
                      incoming().total == existing().total &&
                      incoming().customerNit == existing().customerNit;
                      
        allow delete: if false;
      }

      match /invoices_queue/{queueId} {
        allow read, write: if isOperator(userId) && isValidId(queueId);
      }
      
      match /quotes/{quoteId} {
        allow read: if isOperator(userId);
        allow write: if isOperator(userId) && isValidId(quoteId); 
      }
      
      match /expenses/{expenseId} {
        allow read: if isOperator(userId);
        allow write: if isOperator(userId) && isValidId(expenseId); 
      }
      
      match /orders/{orderId} {
        allow read: if isOperator(userId);
        allow write: if isOperator(userId) && isValidId(orderId);
      }

      match /operators/{operatorId} {
        allow read: if isOperator(userId);
        allow create, update: if isAdmin(userId) && 
                              (request.auth.uid != operatorId || incoming().role == existing().role);
        allow delete: if isAdmin(userId) && operatorId != request.auth.uid;
      }

      match /data/{documentId} {
        allow read, write: if isOperator(userId) && isValidId(documentId);
      }
    }
  }
}
