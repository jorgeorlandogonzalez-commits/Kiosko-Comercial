# 🔑 .env.example - Kiosko Comercial V3.0
# ===============================================================
# ⚠️ COPIA ESTE ARCHIVO COMO .env Y COMPLETA LOS VALORES REALES
# ===============================================================

# 🔒 BACKEND (server.ts / server.cloudrun.ts) - Variables NUNCA expuestas al cliente
# ===============================================================

# Firebase Admin SDK
FIREBASE_PROJECT_ID=gen-lang-client-0213647704

# Google Gemini AI (para Don J)
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# Configuración de servidor
NODE_ENV=development
PORT=3000

# ===============================================================
# 🔐 SEGURIDAD Y FIRMAS DIAN
# ===============================================================

# PIN del certificado .p12 (NUNCA commitear este valor)
CERTIFICATE_PIN=

# Nombre del secreto en Google Secret Manager (opcional, para producción)
CERTIFICATE_PIN_SECRET_NAME=projects/gen-lang-client-0213647704/secrets/certificate-pin

# ===============================================================
# 💳 PASARELA DE PAGOS WOMPI
# ===============================================================

# ⚠️ IMPORTANTE: WOMPI_EVENT_SECRET es la variable que usa el código.
# En desarrollo local, usa la de SANDBOX.
# En producción (Cloud Run), configura la de PROD como WOMPI_EVENT_SECRET.

# Wompi Sandbox (para pruebas locales)
WOMPI_PUBLIC_KEY_SANDBOX=
WOMPI_PRIVATE_KEY_SANDBOX=
WOMPI_EVENT_SECRET_SANDBOX=

# Wompi Producción (para Cloud Run)
WOMPI_PUBLIC_KEY_PROD=
WOMPI_PRIVATE_KEY_PROD=
WOMPI_EVENT_SECRET_PROD=

# Variable ACTIVA que usa el código (paymentsHandler.ts)
# En desarrollo: copiar el valor de WOMPI_EVENT_SECRET_SANDBOX
# En producción: copiar el valor de WOMPI_EVENT_SECRET_PROD
WOMPI_EVENT_SECRET=

# ===============================================================
# 🌐 CORS Y ORIGENES PERMITIDOS
# ===============================================================

# URLs permitidas para CORS (separadas por coma)
ALLOWED_ORIGINS=http://localhost:3000,https://gen-lang-client-0213647704.web.app