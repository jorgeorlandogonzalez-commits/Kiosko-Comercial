{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist/server",
    "rootDir": "./",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["server.ts", "backend/**/*"],
  "exclude": ["node_modules", "dist"]
}
